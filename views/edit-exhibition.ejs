<!DOCTYPE html>
<html lang="<%= lang %>">
<%- include('partials/head') %>
<body>
    <%- include('partials/nav') %>

    <div style="max-width: 600px; margin: 40px auto; padding: 30px; background: white; border: 1px solid #e1e4e8; border-radius: 8px;">
        <h1><%= t('edit_exhibition_title') %></h1>
        <p style="color: #586069; margin-bottom: 25px;"><%= t('edit_exhibition_desc') %></p>

        <% if (typeof error !== 'undefined' && error) { %>
            <p style="color: #d73a49; background: #ffdce0; padding: 10px; border-radius: 6px;"><%= error %></p>
        <% } %>

        <form action="/admin/edit/<%= exhibition.id %>" method="POST" style="display: flex; flex-direction: column; gap: 15px;">
            <div>
                <label for="title" style="display: block; margin-bottom: 5px; font-weight: 500;"><%= t('exhibition_title_label') %> *</label>
                <input type="text" id="title" name="title" value="<%= exhibition.title %>" required style="width: 100%; padding: 8px; border: 1px solid #d1d5da; border-radius: 6px; box-sizing: border-box;">
            </div>
            <div>
                <label for="venueName" style="display: block; margin-bottom: 5px; font-weight: 500;"><%= t('venue_name_label') %> *</label>
                <input type="text" id="venueName" name="venueName" value="<%= exhibition.venueName %>" required placeholder="e.g. Fondation Louis Vuitton" style="width: 100%; padding: 8px; border: 1px solid #d1d5da; border-radius: 6px; box-sizing: border-box;">
            </div>
            <div style="display: flex; gap: 15px;">
                <div style="flex: 1;">
                    <label for="startDate" style="display: block; margin-bottom: 5px; font-weight: 500;"><%= t('start_date_label') %> *</label>
                    <input type="date" id="startDate" name="startDate" value="<%= exhibition.startDate.toISOString().split('T')[0] %>" required style="width: 100%; padding: 8px; border: 1px solid #d1d5da; border-radius: 6px; box-sizing: border-box;">
                </div>
                <div style="flex: 1;">
                    <label for="endDate" style="display: block; margin-bottom: 5px; font-weight: 500;"><%= t('end_date_label') %> *</label>
                    <input type="date" id="endDate" name="endDate" value="<%= exhibition.endDate.toISOString().split('T')[0] %>" required style="width: 100%; padding: 8px; border: 1px solid #d1d5da; border-radius: 6px; box-sizing: border-box;">
                </div>
            </div>
            <div>
                <label for="url" style="display: block; margin-bottom: 5px; font-weight: 500;"><%= t('exhibition_url_label') %></label>
                <input type="url" id="url" name="url" value="<%= exhibition.url || '' %>" placeholder="https://..." style="width: 100%; padding: 8px; border: 1px solid #d1d5da; border-radius: 6px; box-sizing: border-box;">
            </div>
            <div>
                <label for="coverUrl" style="display: block; margin-bottom: 5px; font-weight: 500;"><%= t('cover_url_label') %></label>
                <input type="url" id="coverUrl" name="coverUrl" value="<%= exhibition.coverUrl || '' %>" placeholder="https://.../image.jpg" style="width: 100%; padding: 8px; border: 1px solid #d1d5da; border-radius: 6px; box-sizing: border-box;">
            </div>
            <div style="display: flex; align-items: center; gap: 10px;">
                <input type="checkbox" id="isFree" name="isFree" value="on" <%= exhibition.is_free ? 'checked' : '' %> style="width: 16px; height: 16px;">
                <label for="isFree" style="font-weight: 500;"><%= t('is_free_label') %></label>
            </div>
            <div style="display: flex; gap: 10px; margin-top: 10px;">
                <button type="submit" style="padding: 10px 16px; background-color: #0366d6; color: white; border: none; border-radius: 6px; cursor: pointer; font-weight: 500;"><%= t('update_exhibition_btn') %></button>
                <a href="/" style="padding: 10px 16px; background-color: #f1f1f1; color: #24292e; text-decoration: none; border: 1px solid #d1d5da; border-radius: 6px; text-align: center; font-weight: 500;"><%= t('cancel') %></a>
            </div>
        </form>
    </div>
</body>
</html>