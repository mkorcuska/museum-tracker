<!DOCTYPE html>
<html lang="<%= lang %>">

<%- include('partials/head') %>



    <body>
        <%- include('partials/nav') %>


            <h1>
                <%= t('title') %>
            </h1>

            <%- include('partials/filters') %>

                <p
                    style="text-align: center; color: #6a737d; font-family: 'Playfair Display', serif; font-size: 1.1rem; margin-top: -10px; letter-spacing: 0.1rem; margin-bottom: 30px;">
                    <%= t('found') %> <span id="exhibition-count">
                            <%= exhibitions.length %>
                        </span>
                        <%= t('exhibitions') %>
                </p>

                <div id="exhibition-grid" class="grid">
                    <div id="empty-state"
                        style="display: none; grid-column: 1 / -1; text-align: center; padding: 50px 20px; background-color: #fff; border: 1px dashed #d1d5da; border-radius: 8px;">
                        <div id="empty-state-login" style="display: none;">
                            <h3 style="margin-top: 0; color: #24292e;">
                                <%= t('empty_login_title') %>
                            </h3>
                            <p style="color: #586069; margin-bottom: 20px;">
                                <%= t('empty_login_desc') %>
                            </p>
                            <a href="/login"
                                style="display: inline-block; padding: 8px 16px; background-color: #0366d6; color: #fff; text-decoration: none; border-radius: 6px; font-weight: 500; font-size: 14px;">
                                <%= t('empty_login_btn') %>
                            </a>
                        </div>
                        <div id="empty-state-generic" style="display: none;">
                            <h3 style="margin-top: 0; color: #24292e;">
                                <%= t('empty_generic_title') %>
                            </h3>
                            <p style="color: #586069;">
                                <%= t('empty_generic_desc') %>
                            </p>
                        </div>
                    </div>

                    <!-- Loop through exhibitions using the partial -->
                    <% exhibitions.forEach(exhibition=> { %>
                        <%- include('partials/exhibition-card', { exhibition: exhibition }) %>
                            <% }); %>
                </div>

                <script>
                    window.appConfig = {
                        isLoggedIn: <%= userId ? 'true' : 'false' %>,
                        translations: {
                            'Must See': '<%= t("priority_Must See") %>',
                            'Recommended': '<%= t("priority_Recommended") %>',
                            'Nice to See': '<%= t("priority_Nice to See") %>',
                            'Attended': '<%= t("priority_Attended") %>',
                            'Ignore': '<%= t("priority_Ignore") %>',
                            'Unprioritized': '<%= t("priority_Unprioritized") %>'
                        }
                    };
                </script>
                <script src="/main.js"></script>


                <footer
                    style="text-align: center; margin-top: 50px; padding: 20px; color: #6a737d; font-size: 12px; border-top: 1px solid #e1e4e8;">
                    <%= t('footer_generated') %>
                        <%= new Date().toLocaleString(lang==='fr' ? 'fr-FR' : 'en-US' ) %> | <%= t('footer_source') %>:
                                Paris Open Data 
                </footer>
    </body>

</html>